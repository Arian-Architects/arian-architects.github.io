---
import { getImages } from '@/imagekit'
import MainLayout from '@/layouts/MainLayout.astro'

export async function getStaticPaths() {
  const allImages = await getImages()
  const allProjects = {}
  allImages.forEach((i) => {
    const tmp = i.filePath
    const split = tmp.split('/').filter(Boolean)
    const project = split[0]
    if (!allProjects[project]) allProjects[project] = []
    allProjects[project].push(i)
  })
  return Object.keys(allProjects).map((i) => ({ params: { slug: i }, props: { images: allProjects[i] } }))
}

const { slug } = Astro.params

const specificProj = Astro.props
---

<MainLayout content={{ title: `${slug.split(',')[0]} - Arian Architects` }}>
  <div class="flex flex-col items-center space-y-8 pt-8 text-center">
    <h1 class="text-4xl text-black sm:text-6xl">{slug.split(',')[0]}</h1>
    <h2 class="text-4xl text-gray-500 sm:text-6xl">{slug.split(',')[1]}</h2>
    <a aria-label="Project Images" href="#project">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"></path>
      </svg>
    </a>
    <div id="project" class="mt-10 h-[1px] w-full bg-gray-200 px-4 md:px-32"></div>
  </div>
  <div id="my-gallery" class="row p-8">
    {
      new Array(3).fill(0).map((_, columnIndex) => (
        <div class="column">
          {specificProj.images
            .slice(Math.floor(specificProj.images.length / 3) * columnIndex, Math.floor(specificProj.images.length / 3) * (columnIndex + 1))
            .map(({ url: image, width, height }, index) => {
              const thumbUrl = `${image}?tr=bl-20,w-200,h-200`
              return (
                <a href={image} data-pswp-width={width} data-pswp-height={height} class="img-wrap">
                  <span class="img-placeholder">
                    <img src={thumbUrl} width={width} height={height} alt="" aria-hidden="true" decoding="async" fetchpriority={index === 0 ? 'high' : 'auto'} />
                  </span>
                  <img
                    src={image}
                    width={width}
                    height={height}
                    decoding="async"
                    class="img-full"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    alt={`Image ${index} - ${slug.split(',')[0]}`}
                  />
                </a>
              )
            })}
        </div>
      ))
    }
  </div>
</MainLayout>

<style>
  .img-wrap {
    display: block;
    position: relative;
    overflow: hidden;
  }
  .img-placeholder {
    display: block;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .img-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .img-full {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .img-full.is-loaded {
    opacity: 1;
  }
</style>

<script>
  import 'photoswipe/style.css'
  import pswpModule from 'photoswipe'
  import PhotoSwipeLightbox from 'photoswipe/lightbox'

  window.lightbox = new PhotoSwipeLightbox({
    pswpModule,
    children: 'a',
    gallery: '#my-gallery',
  })

  document.addEventListener(
    'astro:page-load',
    () => {
      if (lightbox) lightbox.init()
      document.querySelectorAll('.img-full').forEach((el) => {
        const img = el as HTMLImageElement
        const removePlaceholder = () => {
          img.classList.add('is-loaded')
          const placeholder = img.parentElement?.querySelector('.img-placeholder')
          if (placeholder) placeholder.remove()
        }
        if (img.complete) removePlaceholder()
        else img.addEventListener('load', removePlaceholder)
      })
    },
    { once: false },
  )
</script>
